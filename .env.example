# 飞书开放平台配置
# 请在飞书开放平台创建企业自建应用，获取以下信息

# 飞书应用 App ID
FEISHU_APP_ID=your_app_id_here

# 飞书应用 App Secret
FEISHU_APP_SECRET=your_app_secret_here

# 飞书多维表格 Token
# 从多维表格URL中获取，格式为：https://xxx.feishu.cn/base/[BITABLE_TOKEN]?table=[TABLE_ID]
FEISHU_BITABLE_TOKEN=your_bitable_token_here

# 飞书多维表格中的表格 ID
FEISHU_TABLE_ID=your_table_id_here

# 配置说明：
# 1. 在飞书开放平台创建企业自建应用
# 2. 开通权限：bitable:record:write（多维表格记录写入权限）
# 3. 将应用发布到企业内部
# 4. 在飞书中创建多维表格，添加以下字段：
#    - 姓名、性别、民族、出生年月、血型、身高、婚姻状况、生育状况
#    - 手机号码、固定电话
#    - 现住地址、户籍地址、户籍性质
#    - 英语等级、英语听说能力、英语读写能力
#    - 其他语种、其他语种听说能力、其他语种读写能力
#    - 最高学历、应聘岗位、期望月薪、最早到岗时间
#    - 岗位意愿一、岗位意愿二
#    - 教育经历（多行文本）
#    - 工作经历（多行文本）
#    - 性格特点、特长、项目经历、工作职责理解、职业规划
#    - 家庭信息（多行文本）
#    - 本公司亲友（多行文本）
#    - 紧急联系人、紧急联系人关系、紧急联系人电话
#    - 兴趣爱好、健康状况、犯罪记录、其他说明
#    - 提交时间
